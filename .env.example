# Environment variables for the project - Example file
# Copy this file to .env and fill in your actual values

# Mistral AI API Keys
MISTRAL_API_KEY_TRANSCRIBE=your_mistral_api_key_for_transcription
MISTRAL_API_KEY_VISION=your_mistral_api_key_for_vision
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# MongoDB Configuration
MONGODB_URI=your_mongodb_connection_string
MONGODB_DATABASE=your_database_name
MONGODB_COLLECTION=your_collection_name

# OpenWebUI Configuration
OPENWEBUI_BASE_URL=your_openwebui_base_url
OPENWEBUI_API_KEY=your_openwebui_api_key
OPENWEBUI_KNOWLEDGE_ID_ATTACHMENTS=your_attachments_knowledge_base_id
OPENWEBUI_KNOWLEDGE_ID_CONVERSATIONS=your_conversations_knowledge_base_id
